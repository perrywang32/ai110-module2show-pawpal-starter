classDiagram
    %% PawPal+ FINAL class diagram (reflects pawpal_system.py as built)
    %% Four core classes: Owner, Pet, CareTask, Schedule
    %% Design: a Pet owns its CareTasks (single source of truth);
    %% a Schedule is the "brain" that gathers, orders, filters, and
    %% validates an owner's tasks for one day; an Owner has many Schedules.
    %%
    %% Changes from the original UML (diagrams/uml.mmd):
    %% - CareTask: added next_occurrence(); markComplete() returns the new
    %%   CareTask (or None), not void.
    %% - Schedule: added sort_by_time(), filter_by_pet(), filter_by_status(),
    %%   and find_conflicts().

    class TaskStatus {
        <<enumeration>>
        PENDING
        COMPLETE
        SKIPPED
    }

    class Frequency {
        <<enumeration>>
        ONCE
        DAILY
        WEEKLY
    }

    class Owner {
        +str name
        +str email
        +list~Pet~ pets
        +list~Schedule~ schedules
        +addPet(pet Pet) void
        +removePet(pet Pet) void
        +getAllTasks() list~CareTask~
        +viewTodayTasks() list~CareTask~
    }

    class Pet {
        +str name
        +str species
        +int age
        +str careNotes
        +list~CareTask~ careTasks
        +updateInfo(name str, species str, age int, careNotes str) void
        +addTask(task CareTask) void
        +getCareNeeds() list~CareTask~
    }

    class CareTask {
        +str taskName
        +date date
        +time time
        +Frequency frequency
        +TaskStatus status
        +Pet pet
        +next_occurrence() CareTask
        +markComplete() CareTask
        +reschedule(newDate date, newTime time) void
        +occurs_on(day date) bool
    }
    %% next_occurrence() and markComplete() return None for a ONCE task.

    class Schedule {
        +date date
        +list~CareTask~ tasks
        +for_owner(owner Owner, day date) Schedule$
        +addTask(task CareTask) void
        +removeTask(task CareTask) void
        +sort_by_time() list~CareTask~
        +getTodayTasks() list~CareTask~
        +filter_by_pet(pet_name str) list~CareTask~
        +filter_by_status(status TaskStatus) list~CareTask~
        +find_conflicts() list~str~
    }

    Owner "1" --> "*" Pet : owns
    Owner "1" --> "*" Schedule : manages
    Pet "1" *-- "*" CareTask : owns
    CareTask "*" --> "1" Pet : belongs to
    Schedule "1" o-- "*" CareTask : references
    CareTask ..> TaskStatus : uses
    CareTask ..> Frequency : uses
